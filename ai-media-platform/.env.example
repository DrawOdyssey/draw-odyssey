# ============================================
# DRAW ODYSSEY - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub!
# ============================================

# --- Supabase ---
# Find these at: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe ---
# Find these at: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Fal.ai ---
# Find this at: fal.ai → Dashboard → Keys
FAL_KEY=your-fal-api-key

# --- Cloudflare R2 ---
# Find these at: cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=media-assets
R2_PUBLIC_URL=https://your-custom-domain-or-r2-url

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
